# Supabase connection for the CareMatch front-end.
# Copy this file to `.env` and fill in your project's values.
# Both are safe to expose in a browser build: the publishable/anon key
# only grants what your Row-Level Security policies allow.
#
# Find them in the Supabase dashboard:
#   Project Settings → API → Project URL   and   Project API keys → anon / publishable
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
